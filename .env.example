# ══════════════════════════════════════════════════════════════════════
# Deleyna – Umgebungsvariablen
#
# Pflicht-Variablen sind NICHT auskommentiert.
# Optionale sind auskommentiert (#) mit Beispielwerten.
#
# Viele Integrationen (Resend, Turnstile, Upstash, Notion, Analytics)
# können AUCH im Admin Panel konfiguriert werden. Dort gesetzte Werte
# haben Vorrang vor .env. Siehe Spalte "Admin Panel" unten.
# ══════════════════════════════════════════════════════════════════════

# ── Datenbank (Pflicht) ──────────────────────────────────────────────
# Lokal (docker-compose): postgresql://postgres:postgres@postgres:5432/payload
# Produktion (Dokploy):   postgresql://USER:PASS@HOST:5432/deleyna
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/payload

# Nur für docker-compose (Produktion: direkt in DATABASE_URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payload

# ── Payload (Pflicht) ────────────────────────────────────────────────
# WICHTIG: In Produktion starken Wert setzen → openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ── URLs (Pflicht) ───────────────────────────────────────────────────
# Lokal: http://localhost:3000 | Produktion: https://deleyna.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# ── S3 Storage (Pflicht) ─────────────────────────────────────────────
# Lokal: MinIO | Produktion: Cloudflare R2, AWS S3, etc.
S3_BUCKET=payload-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000

# ── CRON Jobs ────────────────────────────────────────────────────────
# CRON_SECRET=your-cron-secret-here

# ══════════════════════════════════════════════════════════════════════
# AB HIER: Optionale Integrationen
#
# Diese können ALLE im Admin Panel konfiguriert werden.
# .env-Werte dienen nur als Fallback wenn im Admin nichts gesetzt ist.
# ══════════════════════════════════════════════════════════════════════

# ── Email / Resend (optional) ────────────────────────────────────────
# → Admin Panel: Formulareinstellungen → Automatische E-Mail-Antwort
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_ADDRESS=noreply@deleyna.com
# RESEND_FROM_NAME=Deleyna

# ── Cloudflare Turnstile (optional) ─────────────────────────────────
# → Admin Panel: Formulareinstellungen → Bot-Schutz
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Rate Limiting / Upstash Redis (optional) ─────────────────────────
# → Admin Panel: Formulareinstellungen → Rate Limiting
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Notion Integration (optional) ───────────────────────────────────
# → Admin Panel: Notion-Integration
# NOTION_API_KEY=ntn_xxxxxxxxxxxx
# NOTION_TALENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Analytics (optional) ─────────────────────────────────────────────
# → Admin Panel: SEO → Analytics (Rybbit, Google Analytics, GTM)
# Keine .env-Variablen nötig — alles über Admin Panel.

# ══════════════════════════════════════════════════════════════════════
# AB HIER: Nur über .env konfigurierbar (kein Admin Panel)
# ══════════════════════════════════════════════════════════════════════

# ── Newsletter (optional) ────────────────────────────────────────────
# Resend Audience:
# RESEND_AUDIENCE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Oder Mailchimp:
# MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxx-usXX
# MAILCHIMP_LIST_ID=xxxxxxxxxxxx
# MAILCHIMP_SERVER_PREFIX=usXX

# ── Sonstiges (optional) ────────────────────────────────────────────
# PREVIEW_SECRET=your-preview-secret
# SECURITY_CHECK_TOKEN=your-security-token
# TALENT_UPLOAD_OUTPUT_FORMAT=webp
# ENABLE_GRAPHQL=true
# SKIP_MEDIA_SEED=true

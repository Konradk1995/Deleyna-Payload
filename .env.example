# ── Datenbank ───────────────────────────────────────────────────────
# Lokal (docker-compose): postgresql://postgres:postgres@postgres:5432/payload
# Dokploy: postgresql://USER:PASS@HOST:5432/deleyna
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/payload

# Nur für docker-compose (nicht nötig auf Dokploy)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=payload

# ── Payload ─────────────────────────────────────────────────────────
# WICHTIG: In Produktion starken Wert setzen → openssl rand -base64 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# ── URLs ────────────────────────────────────────────────────────────
# Lokal: http://localhost:3000 | Produktion: https://deleyna.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Optional: CDN-URL für Medien (z. B. https://cdn.deleyna.com)
# NEXT_PUBLIC_IMAGE_CDN_URL=
# Optional: zusätzliche erlaubte Image-Hosts (kommagetrennt)
# NEXT_PUBLIC_IMAGE_REMOTE_HOSTS=

# ── S3 Storage ──────────────────────────────────────────────────────
# Lokal: MinIO | Produktion: Cloudflare R2, AWS S3, etc.
S3_BUCKET=payload-media
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_REGION=us-east-1
S3_ENDPOINT=http://localhost:9000

# ── Cloudflare Turnstile (optional) ────────────────────────────────
# Bot-Schutz für Formulare (DSGVO-konform, cookie-frei)
# Keys: https://dash.cloudflare.com/?to=/:account/turnstile
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
# TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ── Email (optional) ───────────────────────────────────────────────
# RESEND_API_KEY=re_xxxxxxxxxxxx
# RESEND_FROM_ADDRESS=noreply@deleyna.com
# RESEND_FROM_NAME=Deleyna

# ── CRON Jobs (optional) ───────────────────────────────────────────
# CRON_SECRET=your-cron-secret-here

# ── Rate Limiting (optional) ───────────────────────────────────────
# UPSTASH_REDIS_REST_URL=https://<your-db>.upstash.io
# UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxx

# ── Notion Integration (optional) ──────────────────────────────────
# NOTION_API_KEY=ntn_xxxxxxxxxxxx
# NOTION_TALENTS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── GraphQL (optional) ─────────────────────────────────────────────
# ENABLE_GRAPHQL=true
